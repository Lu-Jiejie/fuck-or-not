    "markdown-it": "^14.2.0",
    "sortablejs": "^1.15.7",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@iconify-json/carbon": "^1.2.23",
    "@iconify-json/stash": "^1.2.4",
    "@netlify/functions": "^5.3.0",
    "@types/jszip": "^3.4.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.9.3",
    "@types/sortablejs": "^1.15.9",
    "@unocss/eslint-plugin": "^66.7.0",
    "@unocss/transformer-directives": "^66.7.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "bumpp": "^11.1.0",
    "eslint": "^10.4.1",
    "eslint-plugin-format": "^2.0.1",
    "lint-staged": "^17.0.7",
    "simple-git-hooks": "^2.13.1",
    "taze": "^19.14.1",
    "typescript": "^5.9.3",
    "unocss": "^66.7.0",
    "unplugin-vue-router": "^0.19.1",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "vue-tsc": "^3.3.4"
  },
  "resolutions": {
    "unplugin": "^3.0.0",
    "vite": "^8.0.16"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
